<!-- Skills Section -->
<section id="skills" class="py-20 border-t border-border-light dark:border-border-dark">
  <h2 class="text-3xl font-bold mb-8 text-center">Skills</h2>
  <div class="flex flex-col gap-8">
    {% for group in skills %}
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-widest text-muted-foreground-light dark:text-muted-foreground-dark mb-4">{{ group.type }}</h3>
        <ul class="flex flex-wrap gap-4">

          {% if group.type == "focus" %}
            {% for item in group.focuses %}
              <li class="flex items-center subpixel-antialiased highlight rounded-full bg-muted-light dark:bg-muted-dark px-4 py-2 text-sm font-medium">
                {{ item.focus }}
                {% if item.icon %}{{ item.icon | safe }}{% endif %}
              </li>
            {% endfor %}

          {% elif group.type == "domain" %}
            {% for item in group.domains %}
              <li class="flex items-center subpixel-antialiased highlight rounded-full bg-muted-light dark:bg-muted-dark px-4 py-2 text-sm font-medium">
                {{ item.domain }}
                {% if item.icon %}{{ item.icon | safe }}{% endif %}
              </li>
            {% endfor %}

          {% elif group.type == "tools" %}
            {% for item in group.tools %}
              <li class="flex items-center subpixel-antialiased highlight rounded-full bg-muted-light dark:bg-muted-dark px-4 py-2 text-sm font-medium">
                {{ item.tool }}
                {% if item.icon %}{{ item.icon | safe }}{% endif %}
              </li>
            {% endfor %}
          {% endif %}

        </ul>
      </div>
    {% endfor %}
  </div>
</section>